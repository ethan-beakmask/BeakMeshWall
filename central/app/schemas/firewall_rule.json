{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beakmeshwall.local/schemas/firewall_rule.json",
  "title": "BeakMeshWall Firewall Rule (Stage A+B)",
  "description": "Unified firewall rule schema. Stage A: basic 5-tuple. Stage B adds connection state matching and logging. Translated to native syntax (nftables/iptables/Windows Firewall) by agent driver. See docs/ROADMAP-CONFIG-MANAGEMENT.md.",
  "type": "object",
  "required": ["action", "direction"],
  "additionalProperties": false,
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["A", "B"],
      "description": "Schema stage tag. Optional; informational only."
    },
    "action": {
      "type": "string",
      "enum": ["allow", "drop", "reject"],
      "description": "What to do with matching packets."
    },
    "direction": {
      "type": "string",
      "enum": ["input", "output", "forward"],
      "description": "Traffic direction relative to the host."
    },
    "proto": {
      "type": "string",
      "enum": ["tcp", "udp", "icmp", "any"],
      "default": "any",
      "description": "Protocol. 'any' matches all."
    },
    "src": {
      "type": "string",
      "default": "any",
      "description": "Source: IPv4 address, CIDR, or 'any'.",
      "pattern": "^(any|((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)(/(3[0-2]|[12]?[0-9]))?)$"
    },
    "dst": {
      "type": "string",
      "default": "any",
      "description": "Destination: IPv4 address, CIDR, or 'any'.",
      "pattern": "^(any|((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)(/(3[0-2]|[12]?[0-9]))?)$"
    },
    "sport": {
      "type": "string",
      "default": "any",
      "description": "Source port: integer (1-65535), 'X-Y' range, or 'any'.",
      "pattern": "^(any|[1-9][0-9]{0,4}(-[1-9][0-9]{0,4})?)$"
    },
    "dport": {
      "type": "string",
      "default": "any",
      "description": "Destination port: integer (1-65535), 'X-Y' range, or 'any'.",
      "pattern": "^(any|[1-9][0-9]{0,4}(-[1-9][0-9]{0,4})?)$"
    },
    "comment": {
      "type": "string",
      "maxLength": 255,
      "description": "Free-form note. Will be embedded in native rule comment field where supported."
    },
    "state": {
      "type": "array",
      "description": "Stage B: connection states to match. Empty/absent = no state match.",
      "items": {
        "type": "string",
        "enum": ["new", "established", "related", "invalid"]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "log_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Stage B: emit a log entry for matched packets."
    },
    "log_prefix": {
      "type": "string",
      "maxLength": 32,
      "default": "BMW: ",
      "description": "Stage B: log message prefix. Stripped to 32 chars."
    },
    "log_level": {
      "type": "string",
      "enum": ["debug", "info", "notice", "warning", "error"],
      "default": "info",
      "description": "Stage B: log severity."
    }
  }
}
